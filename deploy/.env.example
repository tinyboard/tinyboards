# =============================================================================
# TinyBoards — Environment Variables Reference
# =============================================================================
#
# This file documents every environment variable the application reads.
# It is the single authoritative reference for deployment configuration.
#
# In production, all values are derived from tinyboards.hjson via configure.sh.
# This file is for documentation only — copy and fill in for manual setups.
#
# Quick start:
#   1. cp tinyboards.example.hjson tinyboards.hjson
#   2. Edit tinyboards.hjson
#   3. ./configure.sh        # generates .env from hjson
#   4. docker compose up -d
#
# =============================================================================

# ---- Database ----

# PostgreSQL username for the application database.
# Required: yes | Default: tinyboards
POSTGRES_USER=tinyboards

# PostgreSQL password. Must be strong in production.
# Required: yes | Default: none
POSTGRES_PASSWORD=changeme_strong_password_here

# PostgreSQL database name.
# Required: yes | Default: tinyboards
POSTGRES_DB=tinyboards

# PostgreSQL host (for scripts and non-Docker setups).
# Required: no | Default: localhost
POSTGRES_HOST=localhost

# PostgreSQL port.
# Required: no | Default: 5432
POSTGRES_PORT=5432

# Full PostgreSQL connection string. Overrides individual POSTGRES_* vars when set.
# Used by the Rust backend (via TINYBOARDS_DATABASE_URL or DATABASE_URL).
# Required: no | Default: built from POSTGRES_* vars
# DATABASE_URL=postgres://tinyboards:changeme@localhost:5432/tinyboards

# Backend-specific database URL. Takes precedence over DATABASE_URL.
# Required: no | Default: falls back to DATABASE_URL
# TINYBOARDS_DATABASE_URL=postgres://tinyboards:changeme@localhost:5432/tinyboards

# PostgreSQL tuning profile. Controls which config file is mounted.
# Options: 1gb, 2gb, 4gb (maps to deploy/postgres/postgresql-{profile}.conf)
# Required: no | Default: 1gb
POSTGRES_PROFILE=1gb

# ---- Auth / JWT ----

# TLS/HTTPS flag. Controls whether auth cookies use the Secure attribute.
# Set to true when serving over HTTPS.
# Required: no | Default: false
TLS_ENABLED=false

# ---- Site / Domain ----

# The public domain name of the instance (no protocol, no port).
# Required: yes | Default: localhost
DOMAIN=localhost

# Whether the instance is served over HTTPS.
# Required: no | Default: false
USE_HTTPS=false

# ---- Frontend (Nuxt) ----

# Public domain for the frontend (used in SSR and client-side URLs).
# Required: yes | Default: localhost
NUXT_PUBLIC_DOMAIN=localhost

# Whether to generate HTTPS URLs on the frontend.
# Required: no | Default: false
NUXT_PUBLIC_USE_HTTPS=false

# Full site URL (protocol + domain). Used for canonical URLs and SEO.
# Required: no | Default: constructed from domain + https flag
NUXT_PUBLIC_SITE_URL=http://localhost

# Internal API host for server-side BFF requests (never exposed to clients).
# Points to the backend container/process.
# Required: yes (in Docker) | Default: http://localhost:8536
NUXT_INTERNAL_API_HOST=http://localhost:8536

# Internal GraphQL endpoint URL (used by the BFF proxy).
# Required: no | Default: {NUXT_INTERNAL_API_HOST}/api/v2/graphql
NUXT_INTERNAL_GQL_HOST=http://localhost:8536/api/v2/graphql

# Backend URL alias used in docker-compose.
# Required: no | Default: same as NUXT_INTERNAL_API_HOST
NUXT_BACKEND_URL=http://backend:8536

# ---- Storage / Uploads ----

# No environment variables — storage is configured in tinyboards.hjson
# under the `storage` and `media` sections. Supports:
#   - fs (local filesystem)
#   - s3 (AWS S3 or compatible)
#   - azure (Azure Blob Storage)
#   - gcs (Google Cloud Storage)

# ---- Image Processing ----

# Image processing settings are stored in the `site` table and managed via
# the admin panel (updateSiteConfig mutation). Defaults shown below.
# Processing is synchronous — images are optimized before the upload response.
#
# image_max_width=4096          Max image width in pixels
# image_max_height=4096         Max image height in pixels
# image_thumbnail_width=300     Thumbnail width in pixels
# image_webp_quality=85         WebP conversion quality (1-100)
# image_convert_to_webp=true    Convert uploads to WebP format
# image_strip_exif=true         Remove EXIF metadata from uploads

# ---- Email ----

# No environment variables — email/SMTP is configured in tinyboards.hjson
# under the `email` section.

# ---- Rate Limits ----

# No environment variables — rate limits are configured in tinyboards.hjson
# under the `rate_limit` section.

# ---- Logging ----

# Rust tracing filter string. Controls log verbosity.
# Examples: info, debug, tinyboards=debug,actix_web=info
# Required: no | Default: info
RUST_LOG=info

# ---- Deployment ----

# Docker image tag for tinyboards containers.
# Required: no | Default: latest
TINYBOARDS_TAG=latest

# Docker Compose project name (prefixes container names).
# Required: no | Default: tinyboards
COMPOSE_PROJECT_NAME=tinyboards

# Path to the tinyboards.hjson config file.
# Used by both backend and frontend to locate the unified config.
# Required: no | Default: /app/config/defaults.hjson
TB_CONFIG_LOCATION=/app/config/defaults.hjson

# ---- Backup (scripts/backup.sh) ----

# Directory to store database backups.
# Required: no | Default: /var/backups/tinyboards
BACKUP_DIR=/var/backups/tinyboards

# Number of days to retain old backups before automatic deletion.
# Required: no | Default: 7
BACKUP_RETAIN_DAYS=7

# ---- Testing ----

# Database URL for integration tests (backend only).
# Required: no (only for running tests)
# TEST_DATABASE_URL=postgres://tinyboards:test@localhost:5432/tinyboards_test
