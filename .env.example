# =============================================================================
# THIS FILE IS AUTO-GENERATED — do not edit directly.
# =============================================================================
#
# All configuration lives in tinyboards.hjson (single source of truth).
# Run ./configure.sh to regenerate this file after changing the hjson.
#
# This .env only exists because docker-compose needs environment variables
# for services that can't read hjson directly (e.g. the postgres container).
#
# Quick start:
#   1. cp tinyboards.example.hjson tinyboards.hjson
#   2. Edit tinyboards.hjson with your settings
#   3. ./configure.sh
#   4. docker compose up -d
# =============================================================================

POSTGRES_USER=tinyboards
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=tinyboards
DOMAIN=localhost
USE_HTTPS=false
TLS_ENABLED=false
NUXT_PUBLIC_SITE_URL=http://localhost
NUXT_PUBLIC_DOMAIN=localhost
NUXT_PUBLIC_USE_HTTPS=false
RUST_LOG=info
TINYBOARDS_TAG=latest
COMPOSE_PROJECT_NAME=tinyboards
